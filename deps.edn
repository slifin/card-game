{:deps {com.rpl/rama-helpers {:mvn/version "0.10.0"}
        org.clojure/clojure {:mvn/version "1.12.0"}}
 :mvn/repos {"maven-releases" {:url "https://nexus.redplanetlabs.com/repository/maven-public-releases"}}
 :aliases {:dev {:extra-paths ["test/resources"]}
           :provided {:extra-deps {com.rpl/rama {:mvn/version "1.1.0"}}}
           :test {:extra-paths ["test"]
                  :extra-deps {io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                  :main-opts ["-m" "cognitect.test-runner"]
                  :exec-fn cognitect.test-runner.api/test}}}